<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="BgPrimaryColor">#0B0D12</Color>
    <Color x:Key="BgSurfaceColor">#13161F</Color>
    <Color x:Key="BgElevatedColor">#1A1F2E</Color>
    <Color x:Key="BgHoverColor">#222838</Color>
    <Color x:Key="AccentPrimaryColor">#4F6EF7</Color>
    <Color x:Key="AccentSecondaryColor">#7C3AED</Color>
    <Color x:Key="AccentSuccessColor">#10B981</Color>
    <Color x:Key="AccentWarningColor">#F59E0B</Color>
    <Color x:Key="AccentDangerColor">#EF4444</Color>
    <Color x:Key="TextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="TextMutedColor">#64748B</Color>
    <Color x:Key="BorderSubtleColor">#2A3145</Color>
    <Color x:Key="BorderFocusColor">#4F6EF7</Color>

    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimaryColor}"/>
    <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurfaceColor}"/>
    <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevatedColor}"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHoverColor}"/>
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimaryColor}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondaryColor}"/>
    <SolidColorBrush x:Key="AccentSuccessBrush" Color="{StaticResource AccentSuccessColor}"/>
    <SolidColorBrush x:Key="AccentWarningBrush" Color="{StaticResource AccentWarningColor}"/>
    <SolidColorBrush x:Key="AccentDangerBrush" Color="{StaticResource AccentDangerColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocusColor}"/>

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#4F6EF7" Offset="0"/>
        <GradientStop Color="#7C3AED" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PageBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B0D12" Offset="0"/>
        <GradientStop Color="#10141D" Offset="0.5"/>
        <GradientStop Color="#0B0D12" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GlassCardBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E61A1F2E" Offset="0"/>
        <GradientStop Color="#CC13161F" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
