<UserControl x:Class="RestaurantOS.WPF.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <StackPanel Margin="0,0,0,20">
                <DockPanel Margin="0,0,0,12">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Raporlar" Style="{StaticResource Heading1}"/>
                        <TextBlock Text="Gelir analizi ve performans metrikleri" Style="{StaticResource PageSubtitle}"/>
                    </StackPanel>
                </DockPanel>
                <StackPanel Orientation="Horizontal">
                <DatePicker SelectedDate="{Binding StartDate}" Margin="24,0,8,0" Width="140"/>
                <DatePicker SelectedDate="{Binding EndDate}" Margin="0,0,8,0" Width="140"/>
                <Button Content="Yükle" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button Content="Excel'e Aktar" Command="{Binding ExportExcelCommand}" Style="{StaticResource PrimaryButton}"/>
                </StackPanel>
            </StackPanel>

            <UniformGrid Columns="3" Margin="0,0,0,16">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Toplam Gelir" Style="{StaticResource CaptionText}"/>
                        <TextBlock Text="{Binding Report.TotalRevenue, Converter={StaticResource Currency}}" Style="{StaticResource MonoAmount}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="Oturum Sayısı" Style="{StaticResource CaptionText}"/>
                        <TextBlock Text="{Binding Report.TotalSessions}" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Ortalama Fiş" Style="{StaticResource CaptionText}"/>
                        <TextBlock Text="{Binding Report.AverageTicket, Converter={StaticResource Currency}}" Style="{StaticResource MonoAmount}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="En Çok Satan (Gelir)" Style="{StaticResource Heading2}" Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding TopItems}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ürün" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="Adet" Binding="{Binding Quantity}" Width="60"/>
                                <DataGridTextColumn Header="Gelir" Binding="{Binding Revenue, Converter={StaticResource Currency}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Ödeme Dağılımı" Style="{StaticResource Heading2}" Margin="0,0,0,8"/>
                        <lvc:PieChart Series="{Binding PaymentSeries}" Height="240"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Garson Performansı" Style="{StaticResource Heading2}" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding WaiterPerformance}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Garson" Binding="{Binding WaiterName}" Width="*"/>
                            <DataGridTextColumn Header="Oturum" Binding="{Binding SessionsOpened}" Width="80"/>
                            <DataGridTextColumn Header="Gelir" Binding="{Binding TotalRevenue, Converter={StaticResource Currency}}" Width="120"/>
                            <DataGridTextColumn Header="Ort. Fiş" Binding="{Binding AverageTicket, Converter={StaticResource Currency}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
