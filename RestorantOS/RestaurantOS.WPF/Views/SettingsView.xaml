<UserControl x:Class="RestaurantOS.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Ayarlar" Style="{StaticResource Heading1}"/>
            <TextBlock Text="Restoran, masa ve kullanıcı yapılandırması" Style="{StaticResource PageSubtitle}" Margin="0,0,0,20"/>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Genel" Style="{StaticResource Heading2}" Margin="0,0,0,12"/>
                    <TextBlock Text="Restoran Adı" Style="{StaticResource CaptionText}"/>
                    <TextBox Text="{Binding AppSettings.RestaurantName}" Style="{StaticResource TextBoxStyle}" Margin="0,4,0,12"/>
                    <TextBlock Text="Varsayılan KDV %" Style="{StaticResource CaptionText}"/>
                    <TextBox Text="{Binding AppSettings.DefaultTaxRate}" Style="{StaticResource TextBoxStyle}" Margin="0,4,0,12"/>
                    <TextBlock Text="Tema Rengi" Style="{StaticResource CaptionText}"/>
                    <TextBox Text="{Binding AppSettings.AccentColor}" Style="{StaticResource TextBoxStyle}" Margin="0,4,0,12"/>
                    <Button Content="Kaydet" Command="{Binding SaveAppSettingsCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Masalar" Style="{StaticResource Heading2}" VerticalAlignment="Center"/>
                        <Button Content="+ Ekle" Command="{Binding AddTableCommand}" Style="{StaticResource SecondaryButton}" Margin="16,0,0,0"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Tables}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding TableNumber}" Width="50"/>
                            <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Bölüm" Binding="{Binding Section}" Width="100"/>
                            <DataGridTextColumn Header="Kapasite" Binding="{Binding Capacity}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Kullanıcılar" Style="{StaticResource Heading2}" VerticalAlignment="Center"/>
                        <Button Content="+ Ekle" Command="{Binding AddUserCommand}" Style="{StaticResource SecondaryButton}" Margin="16,0,0,0"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Users}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ad" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Kullanıcı" Binding="{Binding Username}" Width="120"/>
                            <DataGridTextColumn Header="Rol" Binding="{Binding Role}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Button Content="Veritabanı Yedekle" Command="{Binding BackupDatabaseCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
