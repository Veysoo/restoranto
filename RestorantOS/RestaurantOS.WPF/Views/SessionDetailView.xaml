<UserControl x:Class="RestaurantOS.WPF.Views.SessionDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid DataContext="{Binding}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24"
                      Visibility="{Binding IsLoading, Converter={StaticResource InverseBool}}">
            <StackPanel>
                <!-- Header -->
                <Grid Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Heading2}" FontSize="22">
                            <Run Text="{Binding Session.TableName}"/><Run Text="  #"/><Run Text="{Binding Session.TableNumber}"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource PageSubtitle}">
                            <Run Text="Süre: "/><Run Text="{Binding Session.OpenedAt, Converter={StaticResource Duration}}" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Run Text="  •  "/><Run Text="{Binding Session.GuestCount}"/><Run Text=" misafir"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Content="İptal Et" Command="{Binding CancelSessionCommand}" Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="{StaticResource AccentDangerBrush}"/>
                </Grid>

                <!-- Tabs -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <RadioButton Content="Sipariş Girişi" Style="{StaticResource SectionPill}" GroupName="SessionTab"
                                 IsChecked="{Binding IsOrderTab}" Command="{Binding ShowOrderTabCommand}"/>
                    <RadioButton Content="Hesap &amp; Ödeme" Style="{StaticResource SectionPill}" GroupName="SessionTab"
                                 IsChecked="{Binding IsOrderTab, Converter={StaticResource InverseBool}}"
                                 Command="{Binding ShowPaymentTabCommand}"/>
                </StackPanel>

                <!-- ORDER TAB -->
                <StackPanel Visibility="{Binding IsOrderTab, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="MENÜ" Style="{StaticResource LabelText}"/>
                    <ListBox ItemsSource="{Binding MenuCategories}" SelectedItem="{Binding SelectedCategory}"
                             Background="Transparent" BorderThickness="0" Margin="0,0,0,12">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <RadioButton Content="{Binding Name}" Style="{StaticResource SectionPill}" GroupName="MenuCat"
                                                         IsChecked="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <ItemsControl ItemsSource="{Binding MenuItems}" Margin="0,0,0,20">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.QuickAddOrderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}" Margin="0,0,8,8" Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                            <Setter Property="Width" Value="150"/>
                                            <Setter Property="Height" Value="72"/>
                                            <Setter Property="Padding" Value="12"/>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Price, Converter={StaticResource Currency}}"
                                                   FontFamily="{StaticResource FontMono}" FontSize="14"
                                                   Foreground="{StaticResource AccentPrimaryBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="SİPARİŞ LİSTESİ" Style="{StaticResource LabelText}"/>
                    <ItemsControl ItemsSource="{Binding Session.OrderItems}" Margin="0,0,0,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#141824" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                        CornerRadius="10" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Status, Converter={StaticResource OrderStatusText}}" Style="{StaticResource CaptionText}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='x{0}'}" VerticalAlignment="Center"
                                                   Margin="12,0" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <TextBlock Text="{Binding LineTotal, Converter={StaticResource Currency}}" VerticalAlignment="Center"
                                                       FontFamily="{StaticResource FontMono}" Margin="0,0,8,0"/>
                                            <Button Content="✕" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource GhostButton}" Width="28" Height="28"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Style="{StaticResource CardBorder}">
                        <Grid>
                            <TextBlock Text="Ara Toplam" Style="{StaticResource BodyText}"/>
                            <TextBlock Text="{Binding Session.TotalAmount, Converter={StaticResource Currency}}" HorizontalAlignment="Right" FontFamily="{StaticResource FontMono}"/>
                        </Grid>
                    </Border>

                    <Button Content="Hesap Kes →" Command="{Binding ShowPaymentTabCommand}" Style="{StaticResource PrimaryButton}"
                            Margin="0,16,0,0" HorizontalAlignment="Stretch" Height="44"/>
                </StackPanel>

                <!-- PAYMENT TAB -->
                <StackPanel Visibility="{Binding IsOrderTab, Converter={StaticResource InverseBool}}">
                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Background="#141824">
                        <StackPanel>
                            <TextBlock Text="HESAP ÖZETİ" Style="{StaticResource LabelText}"/>
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="Ara Toplam" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="{Binding Session.TotalAmount, Converter={StaticResource Currency}}" HorizontalAlignment="Right" FontFamily="{StaticResource FontMono}"/>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <TextBlock Text="İndirim" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="{Binding Session.DiscountAmount, Converter={StaticResource Currency}}" HorizontalAlignment="Right" FontFamily="{StaticResource FontMono}"/>
                            </Grid>
                            <Grid Margin="0,6,0,0">
                                <TextBlock Text="KDV" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="{Binding Session.TaxAmount, Converter={StaticResource Currency}}" HorizontalAlignment="Right" FontFamily="{StaticResource FontMono}"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,12,0,12"/>
                            <Grid>
                                <TextBlock Text="TOPLAM TUTAR" Style="{StaticResource Heading2}"/>
                                <TextBlock Text="{Binding Session.FinalAmount, Converter={StaticResource Currency}}"
                                           Style="{StaticResource MonoAmount}" FontSize="28" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <TextBlock Text="Ödenen" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="{Binding Session.PaidAmount, Converter={StaticResource Currency}}" HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentSuccessBrush}" FontFamily="{StaticResource FontMono}"/>
                            </Grid>
                            <Grid Margin="0,4,0,0">
                                <TextBlock Text="Kalan" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="{Binding Session.RemainingAmount, Converter={StaticResource Currency}}" HorizontalAlignment="Right"
                                           Foreground="{StaticResource AccentWarningBrush}" FontFamily="{StaticResource FontMono}" FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="ÖDEME YÖNTEMİ" Style="{StaticResource LabelText}"/>
                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <Button Content="💵 Nakit" Command="{Binding SelectPaymentMethodCommand}" CommandParameter="Cash"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,4,8"/>
                        <Button Content="💳 Kredi Kartı" Command="{Binding SelectPaymentMethodCommand}" CommandParameter="CreditCard"
                                Style="{StaticResource SecondaryButton}" Margin="4,0,0,8"/>
                        <Button Content="💳 Banka Kartı" Command="{Binding SelectPaymentMethodCommand}" CommandParameter="DebitCard"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,4,0"/>
                        <Button Content="🏦 Havale" Command="{Binding SelectPaymentMethodCommand}" CommandParameter="Transfer"
                                Style="{StaticResource SecondaryButton}" Margin="4,0,0,0"/>
                    </UniformGrid>

                    <TextBlock Text="NAKİT VERİLEN" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding CashTendered, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,8"/>
                    <TextBlock Style="{StaticResource CaptionText}" Margin="0,0,0,16">
                        <Run Text="Para Üstü: "/>
                        <Run Text="{Binding ChangeAmount, Converter={StaticResource Currency}}" Foreground="{StaticResource AccentSuccessBrush}"/>
                    </TextBlock>

                    <Button Content="Ödemeyi Kaydet" Command="{Binding SavePaymentCommand}" Style="{StaticResource PrimaryButton}"
                            Height="48" HorizontalAlignment="Stretch" FontSize="15"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Background="{StaticResource BgSurfaceBrush}" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Yükleniyor..." Style="{StaticResource BodyText}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Payment success overlay -->
        <Border Background="#CC000000" Visibility="{Binding ShowPaymentSuccess, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource CardBorder}" Width="360" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="#141824" BorderBrush="{StaticResource AccentSuccessBrush}" BorderThickness="2">
                <StackPanel HorizontalAlignment="Center" Margin="16">
                    <TextBlock Text="✓" FontSize="48" Foreground="{StaticResource AccentSuccessBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding PaymentSuccessMessage}" Style="{StaticResource Heading2}" TextAlignment="Center"
                               Margin="0,12,0,0" TextWrapping="Wrap"/>
                    <TextBlock Text="Masa kapatılıyor..." Style="{StaticResource CaptionText}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
