<UserControl x:Class="RestaurantOS.WPF.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <Button DockPanel.Dock="Right" Content="Yenile" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"/>
            <StackPanel>
                <TextBlock Text="Sipariş Yönetimi" Style="{StaticResource Heading1}"/>
                <TextBlock Text="Mutfak akışını kanban panosu üzerinden yönetin" Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,4,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Bekliyor" Style="{StaticResource Heading2}" Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Pending}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ItemName}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Style="{StaticResource CaptionText}">
                                                <Run Text="Masa "/><Run Text="{Binding TableNumber}"/><Run Text=" x"/><Run Text="{Binding Quantity}"/>
                                            </TextBlock>
                                            <Button Content="→ Hazırlanıyor" Command="{Binding DataContext.MoveToPreparingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource PrimaryButton}" Margin="0,8,0,0" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="4,0,4,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Hazırlanıyor" Style="{StaticResource Heading2}" Margin="0,0,0,8" Foreground="{StaticResource AccentWarningBrush}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Preparing}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ItemName}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TableName}" Style="{StaticResource CaptionText}"/>
                                            <Button Content="→ Servis Edildi" Command="{Binding DataContext.MoveToServedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" Style="{StaticResource PrimaryButton}" Margin="0,8,0,0" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="4,0,4,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Servis Edildi" Style="{StaticResource Heading2}" Margin="0,0,0,8" Foreground="{StaticResource AccentSuccessBrush}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Served}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding ItemName}" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource CardBorder}" Margin="4,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="İptal" Style="{StaticResource Heading2}" Margin="0,0,0,8" Foreground="{StaticResource AccentDangerBrush}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Cancelled}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgElevatedBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8" Opacity="0.6">
                                        <TextBlock Text="{Binding ItemName}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
