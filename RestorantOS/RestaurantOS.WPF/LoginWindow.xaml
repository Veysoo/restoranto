<Window x:Class="RestaurantOS.WPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RestaurantOS"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Width="920" Height="580" ResizeMode="NoResize">
    <Border CornerRadius="20" BorderBrush="#2A3145" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0B0D12" Offset="0"/>
                    <GradientStop Color="#12151E" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Ambient glow -->
            <Ellipse Width="420" Height="420" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-120,-100,0,0" IsHitTestVisible="False" Opacity="0.35">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#664F6EF7" Offset="0"/>
                        <GradientStop Color="#004F6EF7" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="360" Height="360" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-80,-80" IsHitTestVisible="False" Opacity="0.25">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#667C3AED" Offset="0"/>
                        <GradientStop Color="#007C3AED" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <!-- Grid pattern -->
            <Canvas Opacity="0.04" IsHitTestVisible="False">
                <Rectangle Width="2000" Height="1" Fill="#94A3B8" Canvas.Top="60"/>
                <Rectangle Width="2000" Height="1" Fill="#94A3B8" Canvas.Top="120"/>
                <Rectangle Width="2000" Height="1" Fill="#94A3B8" Canvas.Top="180"/>
                <Rectangle Width="1" Height="2000" Fill="#94A3B8" Canvas.Left="80"/>
                <Rectangle Width="1" Height="2000" Fill="#94A3B8" Canvas.Left="160"/>
                <Rectangle Width="1" Height="2000" Fill="#94A3B8" Canvas.Left="240"/>
            </Canvas>

            <Grid Margin="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- Brand panel -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,40,0">
                    <Border Width="52" Height="52" CornerRadius="14" Margin="0,0,0,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4F6EF7" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="R" FontSize="26" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="RestaurantOS" FontSize="42" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Modern restoran operasyonları için tasarlanmış kurumsal yönetim platformu."
                               Style="{StaticResource PageSubtitle}" TextWrapping="Wrap" MaxWidth="380" Margin="0,12,0,32"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#141824" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="14,10" Margin="0,0,12,0">
                            <StackPanel>
                                <TextBlock Text="20 Masa" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="3 Bölüm" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#141824" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="Gerçek Zamanlı" Style="{StaticResource CaptionText}"/>
                                <TextBlock Text="Kat &amp; Sipariş" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Login card -->
                <Border Grid.Column="1" Background="{StaticResource GlassCardBrush}" CornerRadius="16"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Padding="32" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="32" ShadowDepth="0" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="Hoş geldiniz" Style="{StaticResource Heading2}" FontSize="22"/>
                        <TextBlock Text="Hesabınıza giriş yapın" Style="{StaticResource PageSubtitle}" Margin="0,4,0,28"/>

                        <TextBlock Text="KULLANICI ADI" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource TextBoxStyle}" Margin="0,0,0,16"/>

                        <TextBlock Text="ŞİFRE" Style="{StaticResource LabelText}"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource PasswordBoxStyle}" Margin="0,0,0,12"
                                     PasswordChanged="PasswordBox_OnPasswordChanged"/>

                        <Border Background="#1A1018" BorderBrush="#3F1D2E" BorderThickness="1" CornerRadius="8"
                                Padding="12,8" Margin="0,0,0,12"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource AccentDangerBrush}" FontSize="12" TextWrapping="Wrap"/>
                        </Border>

                        <Button Command="{Binding LoginCommand}" Height="46" Margin="0,8,0,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Content" Value="Giriş Yap"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Content" Value="Giriş yapılıyor..."/>
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock Margin="0,20,0,0" Style="{StaticResource CaptionText}" HorizontalAlignment="Center">
                            <Run Text="Demo: "/><Run Text="admin / admin123" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <TextBlock Text="{Binding Version}" Style="{StaticResource CaptionText}"
                       HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20"/>
            <Button Content="✕" Style="{StaticResource GhostButton}" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="12" Click="Close_Click" FontSize="14"/>
        </Grid>
    </Border>
</Window>
