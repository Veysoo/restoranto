<Window x:Class="RestaurantOS.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:RestaurantOS.WPF.Controls"
        Title="RestaurantOS"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}"
        MinWidth="1280" MinHeight="800" WindowState="Maximized">
    <Grid Background="{StaticResource PageBackgroundBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#0E1018" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="True">
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,28">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0" Background="{StaticResource AccentGradientBrush}">
                            <TextBlock Text="R" FontWeight="Bold" FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="RestaurantOS" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Enterprise" Style="{StaticResource CaptionText}" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Nav -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <RadioButton Style="{StaticResource NavButton}" Command="{Binding NavigateDashboardCommand}" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconDashboard}" Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}"
                                  Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" Command="{Binding NavigateFloorCommand}" GroupName="Nav" IsChecked="True">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconFloor}" Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                            <TextBlock Text="Kat Planı" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" Command="{Binding NavigateOrdersCommand}" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconOrders}" Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                            <TextBlock Text="Siparişler" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" Command="{Binding NavigateMenuCommand}" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconMenu}" Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                            <TextBlock Text="Menü" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" Command="{Binding NavigateReportsCommand}" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconReports}" Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                            <TextBlock Text="Raporlar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavButton}" Command="{Binding NavigateSettingsCommand}" GroupName="Nav">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconSettings}" Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0"/>
                            <TextBlock Text="Ayarlar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- User footer -->
                <Border DockPanel.Dock="Bottom" Margin="16,0,16,20" Background="#141824" CornerRadius="12"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#243056">
                            <TextBlock Text="{Binding UserInitials}" Foreground="{StaticResource AccentPrimaryBrush}" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserDisplay}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="Çevrimiçi" Style="{StaticResource CaptionText}" FontSize="10" Foreground="{StaticResource AccentSuccessBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Main area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="#0E1018" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="28,0,16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#141824" CornerRadius="8" Padding="10,6" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 6v6l4 2" Stroke="{StaticResource TextSecondaryBrush}" StrokeThickness="1.5" Fill="Transparent"
                                      Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding CurrentTime}" FontFamily="{StaticResource FontMono}" FontSize="15"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#141824" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="14,8" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconTable}" Fill="{StaticResource AccentWarningBrush}"
                                      Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Style="{StaticResource CaptionText}" VerticalAlignment="Center">
                                    <Run Text="Açık "/>
                                    <Run Text="{Binding OpenTablesCount}" Foreground="{StaticResource AccentWarningBrush}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Background="#141824" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                CornerRadius="10" Padding="14,8" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconRevenue}" Fill="{StaticResource AccentSuccessBrush}"
                                      Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Style="{StaticResource CaptionText}" VerticalAlignment="Center">
                                    <Run Text="Bugün "/>
                                    <Run Text="{Binding TodayRevenue}" Foreground="{StaticResource AccentSuccessBrush}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Button Content="—" Style="{StaticResource GhostButton}" Width="36" Click="Minimize_Click"/>
                        <Button Content="□" Style="{StaticResource GhostButton}" Width="36" Click="Maximize_Click"/>
                        <Button Content="✕" Style="{StaticResource GhostButton}" Width="36" Click="Close_Click"
                                Foreground="{StaticResource AccentDangerBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <controls:TransitioningContentControl Grid.Row="1" Margin="28,24,28,24"
                Content="{Binding CurrentViewModel, Converter={StaticResource VmToView}}"/>
        </Grid>

        <StackPanel x:Name="ToastPanel" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,72,20,0" IsHitTestVisible="False"/>
    </Grid>
</Window>
